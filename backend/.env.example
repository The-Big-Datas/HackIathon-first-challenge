# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Notion
NOTION_TOKEN=ntn_...

# Solo necesario al correr seed/populate_notion.py.
# Es el ID de la pagina padre de Notion que tiene la integracion conectada.
# Lo sacas de la URL: https://www.notion.so/<workspace>/<PAGE_ID>?v=...
NOTION_PARENT_PAGE_ID=

# Los rellena el seed: corre `python seed/populate_notion.py` y pega aqui los IDs
# que imprime en pantalla.
NOTION_DB_ASEGURADOS=
NOTION_DB_POLIZAS=
NOTION_DB_PLANES=
NOTION_DB_COBERTURAS=
NOTION_DB_INFORMES=
NOTION_DB_DECISIONES=

# Modelo Claude
CLAUDE_MODEL=claude-sonnet-4-6
